# Amazon Bedrock Triage & Check-In API - Environment Configuration
# Copy this file to .env and fill in the values below.
# WARNING: Never commit actual AWS credentials (.env files) to git.

# AWS Region to call Bedrock and DynamoDB (default: us-west-2)
AWS_REGION=us-west-2

# The model or inference-profile ID to use for the Converse API.
# e.g., us.amazon.nova-lite-v1:0, anthropic.claude-3-5-sonnet-20240620-v1:0
# This is a placeholder model ID. Retrieve the exact active ID from your AWS console.
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# The name of the DynamoDB table storing patient check-ins and daily counters.
PATIENTS_TABLE_NAME=MediQueuePatientsTable-Dev
