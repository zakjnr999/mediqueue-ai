# MediQueue AI Frontend — Environment Configuration
# ====================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
#
# Available commands:
#   npm run dev      — Start the development server
#   npm run build    — Production build
#   npm run lint     — Run ESLint

# The deployed API Gateway base URL for the MediQueue triage backend.
# This is the CDK CfnOutput named "MediQueueApiUrl".
NEXT_PUBLIC_MEDIQUEUE_API_URL=https://p7xz21rbv0.execute-api.us-west-2.amazonaws.com/dev

# Cognito User Pool Client ID for staff authentication.
# This is the CDK CfnOutput named "MediQueueUserPoolClientId".
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=662td5f2613fh0mtt8cra2dr1c
